{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://getzana.net/zana-lock.schema.json",
  "title": "Zana zana-lock.json schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["packages"],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceId", "version"],
        "properties": {
          "sourceId": {
            "type": "string",
            "minLength": 1,
            "description": "Normalized package ID, e.g. \"github:user/repo\" or \"npm:eslint\"."
          },
          "version": {
            "type": "string",
            "minLength": 1,
            "description": "Exact version/tag that was installed."
          },
          "extras": {
            "type": "object",
            "description": "Optional extension point for per-package metadata.",
            "additionalProperties": true,
            "properties": {
              "integrations": {
                "type": "array",
                "description": "Integration backends to replay for this specific package (e.g. [\"neovim\"]).",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "enum": ["neovim"]
                },
                "uniqueItems": true
              },
              "treesitter_parser_choices": {
                "type": "array",
                "description": "When several Tree-sitter-parser registry packages provide the same language, pins which source id to use for requires / inherit resolution.",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["language", "sourceId"],
                  "properties": {
                    "language": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Tree-sitter language id (e.g. typescript, html_tags)."
                    },
                    "sourceId": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Registry package id (e.g. github:tree-sitter/tree-sitter-typescript)."
                    }
                  }
                }
              },
              "treesitter_query_choices": {
                "type": "array",
                "description": "When several Tree-sitter-queries registry packages provide the same language for an integration, pins which source id to install for Neovim query artifacts.",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["language", "integration", "sourceId"],
                  "properties": {
                    "language": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Tree-sitter language id (e.g. typescript)."
                    },
                    "integration": {
                      "type": "string",
                      "minLength": 1,
                      "enum": ["neovim"],
                      "description": "Editor integration this choice applies to."
                    },
                    "sourceId": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Registry package id (e.g. github:neovim-treesitter/nvim-treesitter-queries-typescript)."
                    }
                  }
                }
              },
              "treesitter_external_queries": {
                "type": "array",
                "description": "Pinned git revisions (full commit SHA) for optional Neovim tree-sitter external_queries repos. Multiple entries may share the same language when several query-only repositories apply; each row is keyed by language plus repo_url.",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["language", "repo_url", "ref"],
                  "properties": {
                    "language": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Tree-sitter language id matching the registry build row."
                    },
                    "repo_url": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Git remote URL of the queries-only repo (must match registry when applying the pin)."
                    },
                    "ref": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Resolved commit SHA (e.g. from git rev-parse HEAD after clone)."
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

